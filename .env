# =============================================================================
# 🌪️ MITANDRINA - Configuration Globale
# Variables partagées entre tous les services
# =============================================================================

# -----------------------------------------------------------------------------
# SECURITÉ
# -----------------------------------------------------------------------------
# JWT Secret (doit être identique pour FastAPI et NodeJS)
JWT_SECRET=mitandrina-super-secret-key-change-in-production

# -----------------------------------------------------------------------------
# CLÉS API EXTERNES
# -----------------------------------------------------------------------------
# OpenWeather API (https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# NASA FIRMS (https://firms.modaps.eosdis.nasa.gov/)
NASA_FIRMS_API_KEY=your_nasa_firms_key_here

# Twilio (https://www.twilio.com/)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase (https://console.firebase.google.com/)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# SendGrid (https://sendgrid.com/)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# BASE DE DONNÉES (docker-compose.yml les surcharge)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mitandrina

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# ENVIRONNEMENT
# -----------------------------------------------------------------------------
NODE_ENV=development
DEBUG=false
LOG_LEVEL=info
