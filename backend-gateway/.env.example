# 🌪️ MITANDRINA - Configuration Gateway Node.js
# Copier ce fichier en .env

NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://mitandrina.vercel.app

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=mitandrina
PGUSER=postgres
PGPASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT (même clé que FastAPI)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES=7d

# AI Service URL
AI_SERVICE_URL=http://localhost:8000

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase (Push notifications)
FIREBASE_PROJECT_ID=your_firebase_project
FIREBASE_PRIVATE_KEY=your_firebase_private_key

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_key
FROM_EMAIL=noreply@mitandrina.mg
