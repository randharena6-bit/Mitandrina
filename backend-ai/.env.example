# 🌪️ MITANDRINA - Configuration FastAPI AI Services
# Copier ce fichier en .env et remplir les valeurs

# App
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mitandrina
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/mitandrina

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_URL=redis://localhost:6379/1

# External APIs
OPENWEATHER_API_KEY=your_openweather_api_key
NASA_FIRMS_API_KEY=your_nasa_firms_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890
FIREBASE_PROJECT_ID=your_firebase_project

# ML Models Path
MODEL_PATH=./models

# JWT (shared with NodeJS)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
